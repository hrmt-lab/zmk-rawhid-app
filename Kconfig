config RAWHID_APP
    bool "RawHID application protocol layer"
    depends on RAW_HID
    help
      Parse host RawHID packets (HELLO / APP_LAYER / TIME_SYNC / AI_USAGE)
      delivered by zmk-raw-hid via raw_hid_received_event, reply to HELLO,
      and expose decoded state to other modules through getters.

      This is a generic, keyboard-agnostic layer: a keyboard config only needs
      to add this module and enable the options below; no per-keyboard C code.

config RAWHID_APP_LAYER_CONTROL
    bool "Enable RawHID APP_LAYER host layer control"
    depends on RAW_HID
    select RAWHID_APP
    help
      Handle APP_LAYER (0x30) packets that let a host activate / clear one ZMK
      layer.

config RAWHID_APP_TIME_SYNC
    bool "Enable RawHID TIME_SYNC"
    depends on RAW_HID
    select RAWHID_APP
    help
      Handle TIME_SYNC (0x20) packets and expose formatted local time through
      rawhid_app_time_sync_format() / rawhid_app_time_sync_wants_seconds().

config RAWHID_APP_AI_USAGE
    bool "Enable RawHID AI_USAGE"
    depends on RAW_HID
    select RAWHID_APP
    help
      Handle AI_USAGE (0x10) packets (Codex / Claude Code 5h and 7d usage) and
      expose the latest per-provider state through rawhid_app_ai_usage_get().

config RAWHID_APP_BATTERY_REPORT
    bool "Enable RawHID BATTERY_STATUS uplink"
    depends on RAW_HID
    select RAWHID_APP
    help
      Send central/self and split peripheral battery levels to the host.
      Source 0 is the central/self RawHID endpoint; sources 1..3 are
      peripheral slots. Level 0xff means unknown, not available, or
      disconnected.

config RAWHID_APP_HOST_ACTION
    bool "Enable RawHID HOST_ACTION behavior uplink"
    depends on RAW_HID
    select RAWHID_APP
    help
      Enable the &host_action behavior to send action ID/value pairs to the host.

config RAWHID_APP_KEY_STATS
    bool "Enable RawHID KEY_STATS uplink"
    depends on RAW_HID
    select RAWHID_APP
    help
      Count key presses in a uint16_t array sized by ZMK_KEYMAP_LEN and
      periodically send deltas to the host. This is opt-in because it consumes
      RAM proportional to the physical key count.

config RAWHID_APP_KEY_PRESS
    bool "Enable RawHID KEY_PRESS uplink"
    depends on RAW_HID
    select RAWHID_APP
    help
      Send each key press and release event to the host immediately.

config RAWHID_APP_LAYER_STATE_REPORT
    bool "Enable RawHID LAYER_STATE uplink"
    depends on RAW_HID
    select RAWHID_APP
    help
      Send the current highest active layer and layer-state mask to the host
      after layer changes and after HOST_HELLO.
